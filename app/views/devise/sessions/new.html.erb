<% content_for :title, "Sign in" %>

<div class="min-h-screen flex">
  <!-- Left branding panel -->
  <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-gray-900 to-indigo-950 flex-col justify-between p-12">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-xl bg-indigo-500 flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
      </div>
      <span class="text-white font-semibold text-sm">Personal Finance Agent</span>
    </div>

    <div>
      <h2 class="text-3xl font-bold text-white leading-tight mb-4">Your money,<br>finally under control.</h2>
      <p class="text-gray-400 text-sm mb-8">Connect your bank accounts and get AI-powered insights into your spending habits.</p>
      <ul class="space-y-3">
        <% [
          ["AI-powered spending insights", "M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"],
          ["Automatic bank sync via Plaid", "M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"],
          ["Subscription & recurring charge tracker", "M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"],
          ["Weekly & monthly financial reports", "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"],
        ].each do |label, path| %>
          <li class="flex items-center gap-3 text-sm text-gray-300">
            <div class="flex-shrink-0 w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <%= label %>
          </li>
        <% end %>
      </ul>
    </div>

    <p class="text-gray-600 text-xs">Powered by Plaid, Ruby on Rails &amp; Claude AI</p>
  </div>

  <!-- Right form panel -->
  <div class="flex-1 flex items-center justify-center bg-gray-50 px-6 py-12">
    <div class="w-full max-w-md">
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Welcome back</h1>
        <p class="text-sm text-gray-500 mt-1">Sign in to your account to continue</p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="space-y-5">
            <div>
              <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
                <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
                  <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" %>
                <% end %>
              </div>
              <%= f.password_field :password, autocomplete: "current-password",
                  class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            </div>

            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
              <%= f.label :remember_me, class: "text-sm text-gray-600 select-none" %>
            </div>

            <%= f.submit "Sign in", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl px-4 py-3 text-sm transition cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <p class="text-center text-sm text-gray-500 mt-6">
        Don't have an account?
        <%= link_to "Create one", new_registration_path(resource_name), class: "font-semibold text-indigo-600 hover:text-indigo-800" %>
      </p>
    </div>
  </div>
</div>
