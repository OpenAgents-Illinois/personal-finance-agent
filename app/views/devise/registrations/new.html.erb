<% content_for :title, "Create account" %>

<div class="min-h-screen flex">
  <!-- Left branding panel -->
  <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-gray-900 to-indigo-950 flex-col justify-between p-12">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-xl bg-indigo-500 flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
      </div>
      <span class="text-white font-semibold text-sm">Personal Finance Agent</span>
    </div>

    <div>
      <h2 class="text-3xl font-bold text-white leading-tight mb-4">Start understanding<br>your finances today.</h2>
      <p class="text-gray-400 text-sm mb-8">Join and get a complete picture of your spending in minutes.</p>
      <ul class="space-y-3">
        <% [
          "AI-powered spending insights",
          "Automatic bank sync via Plaid",
          "Subscription & recurring charge tracker",
          "Weekly & monthly financial reports",
        ].each do |label| %>
          <li class="flex items-center gap-3 text-sm text-gray-300">
            <div class="flex-shrink-0 w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <%= label %>
          </li>
        <% end %>
      </ul>
    </div>

    <p class="text-gray-600 text-xs">Powered by Plaid, Ruby on Rails &amp; Claude AI</p>
  </div>

  <!-- Right form panel -->
  <div class="flex-1 flex items-center justify-center bg-gray-50 px-6 py-12">
    <div class="w-full max-w-md">
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Create your account</h1>
        <p class="text-sm text-gray-500 mt-1">Get started in under a minute</p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="space-y-5">

            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
                <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
                    class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
              </div>
              <div>
                <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
                <%= f.text_field :last_name, autocomplete: "family-name",
                    class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
              </div>
            </div>

            <div>
              <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.email_field :email, autocomplete: "email",
                  class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            </div>

            <div>
              <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.password_field :password, autocomplete: "new-password",
                  class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
              <p class="text-xs text-gray-400 mt-1"><%= @minimum_password_length %> characters minimum</p>
            </div>

            <div>
              <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "w-full rounded-xl border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            </div>

            <%= f.submit "Create account", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl px-4 py-3 text-sm transition cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <p class="text-center text-sm text-gray-500 mt-6">
        Already have an account?
        <%= link_to "Sign in", new_session_path(resource_name), class: "font-semibold text-indigo-600 hover:text-indigo-800" %>
      </p>
    </div>
  </div>
</div>
